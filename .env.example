# Required
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database (async driver for app, sync driver for Alembic)
DATABASE_URL=postgresql+asyncpg://ade:ade_password@localhost:5432/ade_db
DATABASE_URL_SYNC=postgresql+psycopg2://ade:ade_password@localhost:5432/ade_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Embeddings (set at least one API key)
OPENAI_API_KEY=
VOYAGE_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Model configuration
DEFAULT_CODEGEN_MODEL=claude-sonnet-4-20250514
DEFAULT_RERANK_MODEL=claude-haiku-235-20250301

# LLM cache TTL in seconds (default: 1 hour)
LLM_CACHE_TTL_SECONDS=3600

# Sandbox
SANDBOX_BACKEND=docker  # "docker" or "mock"
SANDBOX_DOCKER_IMAGE=ade-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=60
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0
SANDBOX_NETWORK_DISABLED=true
